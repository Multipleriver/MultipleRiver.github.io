      <title>浅证方波拟合中的振铃</title>
      <link>http://localhost:1313/posts/%E6%B5%85%E8%AF%81%E6%96%B9%E6%B3%A2%E6%8B%9F%E5%90%88%E4%B8%AD%E7%9A%84%E6%8C%AF%E9%93%83/</link>
